generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // The runtime datasource URL is provided via prisma.config.ts for Prisma v7+
  // url      = env("DATABASE_URL")
}

model Instructor {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  timezone  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  templates ClassTemplate[]
  sessions  Session[]
  userAuth  UserAuth?
}

model Student {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  enrollments Enrollment[]
  waitlistEntries WaitlistEntry[]
}

model ClassTemplate {
  id                     String   @id @default(uuid())
  instructorId           String
  instructor             Instructor @relation(fields: [instructorId], references: [id])
  title                  String
  description            String?
  isGroup                Boolean  @default(true)
  capacity               Int?
  recurrenceRule         String?
  startTimeLocal         String   // e.g. 18:30
  durationMinutes        Int
  active                 Boolean  @default(true)
  reminderOffsetMinutes  Int      @default(1440)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  sessions               Session[]
}

model Session {
  id              String   @id @default(uuid())
  templateId      String?
  template        ClassTemplate? @relation(fields: [templateId], references: [id])
  instructorId    String
  instructor      Instructor @relation(fields: [instructorId], references: [id])
  startUtc        DateTime
  endUtc          DateTime
  capacitySnapshot Int?
  status          String   @default("scheduled")
  location        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  enrollments   Enrollment[]   // Relación inversa con Enrollment
  reminderJobs  ReminderJob[]  // Relación inversa con ReminderJob
  waitlistEntries WaitlistEntry[]
  
  @@unique([instructorId, startUtc])
}

model Enrollment {
  id         String   @id @default(uuid())
  sessionId  String
  studentId  String
  status     String   @default("active")
  enrolledAt DateTime @default(now())
  cancelledAt DateTime?

  student Student @relation(fields: [studentId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, studentId])
}

model WaitlistEntry {
  id        String   @id @default(uuid())
  sessionId String
  studentId String
  position  Int
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@index([sessionId, position])
}

model ReminderJob {
  id String @id @default(uuid())
  sessionId String
  studentId String?
  scheduledAtUtc DateTime
  sentAtUtc DateTime?
  attempts Int @default(0)
  status String @default("pending")
  providerResponse String?

  session Session @relation(fields: [sessionId], references: [id])

  // Unique constraint for idempotent scheduling: one reminder per (session, student, scheduled time)
  @@unique([sessionId, studentId, scheduledAtUtc])
}

model UserAuth {
  id           String @id @default(uuid())
  instructorId String @unique
  username     String @unique
  passwordHash String

  instructor Instructor @relation(fields: [instructorId], references: [id])
}
